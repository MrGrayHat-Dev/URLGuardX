# ============================================================
#  URLGuardX — .gitignore  (IntelliJ + Spring Boot + Maven)
# ============================================================

# ---------- SECRETS — NEVER COMMIT ----------
.env
*.env
.env.*

# ---------- MAVEN ----------
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ---------- INTELLIJ IDEA ----------
.idea/
*.iml
*.iws
*.ipr
out/
# Keep shared run configs if you want (optional — comment out to share them)
.idea/runConfigurations/

# ---------- SPRING BOOT ----------
spring-shell.log
*.log
logs/

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ---------- DOCKER ----------
docker-compose.override.yml

# ---------- JAVA ----------
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*
